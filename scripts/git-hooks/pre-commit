#!/usr/bin/env bash
# Agent harness — hard quality gate before a commit lands ("keep quality left").
# Computational sensors only: deterministic, fast, no AI.
#   Rust  : just lint  (rustfmt --check + clippy -D warnings)
#   Swift : swiftformat --lint on staged files (format check, no compile)
#
# Scoped to what's actually staged so docs-only / Swift-only commits stay fast.
# Emergency bypass: git commit --no-verify
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

staged="$(git diff --cached --name-only --diff-filter=ACM)"

if printf '%s\n' "$staged" | grep -qE '\.rs$'; then
  echo "▶ pre-commit: just lint (rustfmt --check + clippy -D warnings)"
  if command -v just >/dev/null 2>&1; then
    just lint
  else
    cargo fmt --all --check
    cargo clippy --all-targets -- -D warnings
  fi
fi

swift_files="$(printf '%s\n' "$staged" | grep -E '\.swift$' | grep -vE 'bindings/|SwiftTerm/' || true)"
if [ -n "$swift_files" ] && command -v swiftformat >/dev/null 2>&1; then
  echo "▶ pre-commit: swiftformat --lint"
  # shellcheck disable=SC2086
  swiftformat --lint $swift_files
fi

echo "✓ pre-commit gate passed"

{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".cursor/rules/*.md",
    ".cursor/rules/*.mdc",
    ".github/copilot-instructions.md"
  ],
  "formatter": {
    "rustfmt": {
      "extensions": [".rs"]
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}
